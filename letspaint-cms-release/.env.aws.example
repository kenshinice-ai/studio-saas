# Copy values into systemd service Environment= lines if needed.
PORT=8000
CMS_DATA_DIR=/opt/letspaint-cms/data
LPCMS_VENV=/opt/letspaint-cms/.venv
# Set to 1 only after you access CMS exclusively over HTTPS.
COOKIE_SECURE=0
# Normally leave empty; same-origin frontend does not need CORS.
CORS_ORIGIN=
