-          `${p.student_limit} students<br>${p.user_limit} users<br>${p.storage_limit_mb} MB`,
-          `<div class="actions"><button class="secondary" onclick="editPlan('${p.code}')">Edit</button><button class="danger" onclick="deletePlan('${p.code}')">Delete</button></div>`
-        ])).join('') || row(['No plans.', '', '', '']);
-        $('tenantsBody').innerHTML = tenants.map((t) => row([
-          `<strong>${text(t.name)}</strong><br><code>${t.slug}</code><br><span class="muted">${text(t.workspace_path)}</span><br><a href="/${t.slug}">Open CMS</a>`,
-          pill(t.status),
-          `<strong>${t.plan_code}</strong>`,
-          `${pill(t.subscription_status || '-')}<br><span class="muted">${dateOnly(t.starts_at) || '-'} to ${dateOnly(t.ends_at) || 'open'}</span>`,
-          `${t.student_count} students<br>${t.storage_used_mb} MB`,
