-/* ── Tab switching ── */
-function switchTab(t) {
-  document.getElementById('sec-reg').classList.toggle('hidden',    t!=='reg');
-  document.getElementById('sec-success').classList.add('hidden');
-  document.getElementById('sec-bal').classList.toggle('hidden',    t!=='bal');
