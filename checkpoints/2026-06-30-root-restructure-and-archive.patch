-    const dateOnly = (value) => value ? String(value).slice(0, 10) : '';
-    const money = (value) => `AUD ${Number(value || 0)}`;
-    function show(message, type = 'success') {
-      $('messageBox').className = `panel ${type === 'error' ? 'error' : 'success'}`;
-      $('messageBox').textContent = message;
-      $('messageBox').hidden = false;
-    }
-    async function api(path, options = {}) {
-      const base = $('baseUrl').value.replace(/\/$/, '');
-      const res = await fetch(base + path, {
-        ...options,
-        headers: { 'Content-Type': 'application/json', ...(options.headers || {}) }
-      });
-      const data = await res.json().catch(() => ({}));
-      if (!res.ok) throw new Error(data.message || data.error || `${res.status} ${path}`);
-      return data;
-    }
-    function row(cells) { return `<tr>${cells.map((c) => `<td>${c}</td>`).join('')}</tr>`; }
-    function pill(value) {
-      const cls = value === 'active' || value === 'trialing' || value === 'trial' ? 'pill' : value === 'past_due' ? 'pill warn' : 'pill red';
-      return `<span class="${cls}">${text(value)}</span>`;
-    }
-    function fillPlanSelect() {
-      $('tenantPlan').innerHTML = plans.map((p) => `<option value="${p.code}">${p.name} (${p.code})</option>`).join('');
-    }
-    function resetTenantForm() {
-      editingTenantId = '';
-      $('tenantFormTitle').textContent = 'Add Tenant';
-      ['tenantName','tenantSlug','startsAt','endsAt','currentPeriodEndsAt'].forEach((id) => $(id).value = '');
-      $('tenantSlug').disabled = false;
-      $('tenantStatus').value = 'trial';
-      $('subscriptionStatus').value = 'trialing';
-      if (plans[0]) $('tenantPlan').value = plans[0].code;
-    }
-    function editTenant(id) {
-      const t = tenants.find((item) => item.id === id);
-      if (!t) return;
-      editingTenantId = id;
-      $('tenantFormTitle').textContent = `Edit ${t.name}`;
-      $('tenantName').value = t.name;
-      $('tenantSlug').value = t.slug;
-      $('tenantSlug').disabled = true;
-      $('tenantStatus').value = t.status;
-      $('tenantPlan').value = t.plan_code;
-      $('subscriptionStatus').value = t.subscription_status || 'trialing';
-      $('startsAt').value = dateOnly(t.starts_at);
-      $('endsAt').value = dateOnly(t.ends_at);
-      $('currentPeriodEndsAt').value = dateOnly(t.current_period_ends_at);
-    }
-    async function saveTenant() {
-      const payload = {
-        name: $('tenantName').value,
-        slug: $('tenantSlug').value,
-        status: $('tenantStatus').value,
-        planCode: $('tenantPlan').value,
-        subscriptionStatus: $('subscriptionStatus').value,
-        startsAt: $('startsAt').value || null,
-        endsAt: $('endsAt').value || null,
-        currentPeriodEndsAt: $('currentPeriodEndsAt').value || null
-      };
-      await api(editingTenantId ? `/admin/tenants/${editingTenantId}` : '/admin/tenants', {
-        method: editingTenantId ? 'PATCH' : 'POST',
-        body: JSON.stringify(payload)
-      });
