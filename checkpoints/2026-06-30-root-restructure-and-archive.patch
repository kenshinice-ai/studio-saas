-function renderPortfolio(items, sid, token) {
-  _portItems = items; _portToken = token; _portSid = sid;
-  const container = document.getElementById('bal-portfolio');
-  const grid      = document.getElementById('port-grid');
-  const empty     = document.getElementById('port-empty');
-  const count     = document.getElementById('port-count');
-  grid.innerHTML  = '';
-  count.textContent = items.length > 0 ? `(${items.length} 张)` : '';
-  if (items.length === 0) {
-    empty.classList.remove('hidden');
-    grid.classList.add('hidden');
-  } else {
-    empty.classList.add('hidden');
-    grid.classList.remove('hidden');
-    items.forEach((item, idx) => {
-      const div = document.createElement('div');
-      // M6: port-thumb for active feedback; M7: relative for skeleton overlay
-      div.className = 'port-thumb relative rounded-xl overflow-hidden bg-gray-100';
-      div.style.aspectRatio = '1';
-      div.onclick = () => openLightbox(idx);
-      // Sanitise strings to prevent XSS
-      const safeSid   = encodeURIComponent(sid);
-      const safeFile  = encodeURIComponent(item.filename || '');
-      const safeToken = encodeURIComponent(token);
-      const safeDate  = fmtPortDate(item.date).replace(/[<>&"]/g, '');
-      // #9 fix: also show note in thumbnail (consistent with admin view)
-      const safeNote  = String(item.note  || '').replace(/[<>&"]/g, '');
-      const skId      = `sk-r-${idx}`;
-      div.innerHTML =
-        // M7: skeleton shown until image loads
-        `<div class="img-skel" id="${skId}"></div>` +
