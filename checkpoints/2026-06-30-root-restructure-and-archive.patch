-/* ── Balance query ── */
-async function queryBalance() {
-  const name  = document.getElementById('b-name').value.trim();
-  const phone = document.getElementById('b-phone').value.trim();
-  const err   = document.getElementById('bal-err');
-  err.classList.add('hidden');
-  document.getElementById('bal-result').classList.add('hidden');
-  document.getElementById('bal-nomatch').classList.add('hidden');
-  document.getElementById('bal-history').classList.add('hidden');
-  document.getElementById('bal-portfolio').classList.add('hidden');
-  _portItems = []; _portToken = ''; _portSid = '';
-
-  if (!name || !phone) { showErr(err, '请填写姓名和手机号 / Please enter both name and mobile.'); return; }
-
-  const btn = event.currentTarget;
-  btn.textContent = '查询中... / Checking...';
-  btn.disabled = true;
-
-  try {
-    const r   = await fetch('/api/balance', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name, phone}) });
-    const res = await r.json();
-    if (res.match) {
-      const bal = parseInt(res.balance, 10) || 0;
-      document.getElementById('bal-name').textContent = res.name;
-      document.getElementById('bal-num').textContent  = bal;
-      // Colour and warning based on balance level
-      const card   = document.getElementById('bal-card');
-      const numEl  = document.getElementById('bal-num');
-      const warnEl = document.getElementById('bal-warn');
-      if (bal === 0) {
-        card.className   = 'bg-red-50 border border-red-300 rounded-2xl p-5 text-center';
-        numEl.className  = 'text-5xl font-bold text-red-600 mb-1';
-        warnEl.className = 'text-sm font-bold mt-3 pt-3 border-t border-red-200 text-red-600';
-        warnEl.textContent = '⚠️ 课时已用完，请联系老师续课！/ No classes left — please contact your teacher.';
-        warnEl.classList.remove('hidden');
-      } else if (bal <= 2) {
-        card.className   = 'bg-orange-50 border border-orange-300 rounded-2xl p-5 text-center';
-        numEl.className  = 'text-5xl font-bold text-orange-500 mb-1';
-        warnEl.className = 'text-sm font-bold mt-3 pt-3 border-t border-orange-200 text-orange-600';
-        warnEl.textContent = '⚡ 课时即将用完，请考虑续课。/ Running low — consider topping up.';
-        warnEl.classList.remove('hidden');
-      } else {
-        card.className  = 'bg-indigo-50 border border-indigo-200 rounded-2xl p-5 text-center';
-        numEl.className = 'text-5xl font-bold text-indigo-600 mb-1';
-        warnEl.classList.add('hidden');
-      }
-      document.getElementById('bal-result').classList.remove('hidden');
-
-      // Render class history
-      const histContainer = document.getElementById('bal-history');
-      const histList      = document.getElementById('bal-history-list');
-      const histEmpty     = document.getElementById('bal-history-empty');
-      histList.innerHTML  = '';
-
-      const logs  = res.logs || [];
-      const total = res.total_checkins || logs.length;
-      if (logs.length > 0) {
-        histEmpty.classList.add('hidden');
-        logs.forEach((l, idx) => {
-          const dateStr = String(l.date).split(',')[0]; // strip time portion
-          const row = document.createElement('div');
-          row.className = 'px-4 py-3 flex items-center gap-3';
-          row.innerHTML =
-            `<span class="text-green-500 text-sm flex-shrink-0">✅</span>` +
-            `<span class="text-sm text-gray-700 flex-1">${dateStr}</span>` +
-            `<span class="text-xs text-gray-400 flex-shrink-0">第 ${total - idx} 次</span>`;
-          histList.appendChild(row);
-        });
-      } else {
-        histEmpty.classList.remove('hidden');
-      }
-      histContainer.classList.remove('hidden');
-
-      // Fetch portfolio (silently — optional feature)
-      fetch('/api/portfolio/token', {
-        method: 'POST',
-        headers: {'Content-Type': 'application/json'},
-        body: JSON.stringify({name, phone})
-      }).then(r => r.json()).then(data => {
-        if (data.ok) renderPortfolio(data.portfolio || [], data.sid, data.token);
-      }).catch(() => {});  // portfolio is optional — don't break balance display on failure
-
-    } else if (r.status === 429) {
-      /* S4: rate-limited — show the real reason instead of "no match" */
-      showErr(err, res.error || '查询太频繁，请 1 分钟后再试。/ Too many queries, please wait a minute.');
-    } else {
-      document.getElementById('bal-nomatch').classList.remove('hidden');
-    }
-  } catch(e) {
-    showErr(err, '网络错误，请重试。/ Network error, please try again.');
-  } finally {
-    btn.textContent = '查询余额 / Check Balance';
-    btn.disabled = false;
-  }
-}
-
-/* ── Portfolio ── */
-// D6+D7: convert YYYY-MM-DD → DD/MM/YYYY for display (storage stays ISO)
-function fmtPortDate(s) {
-  if (!s) return '';
-  const m = String(s).match(/^(\d{4})-(\d{2})-(\d{2})/);
-  return m ? `${m[3]}/${m[2]}/${m[1]}` : s;
-}
