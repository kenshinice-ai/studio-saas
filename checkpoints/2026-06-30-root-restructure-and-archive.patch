-/* ── Photo handling ── */
-async function handlePhotoSelect(input) {
-  const file = input.files[0];
-  if (!file) return;
-  if (file.size > 5 * 1024 * 1024) {
-    alert('照片不能超过 5MB / Photo must be under 5MB');
-    input.value = ''; return;
-  }
-  document.getElementById('photo-btn-text').textContent = '上传中... / Uploading...';
-  try {
-    const fd = new FormData();
-    fd.append('file', file);
-    const r   = await fetch('/api/upload-public', { method:'POST', body:fd });
-    const res = await r.json();
-    if (res.filename) {
-      document.getElementById('r-photo').value = res.filename;
-      /* S1: /photos/ is now admin-only — preview the local file directly
-         via FileReader instead of fetching it back from the server. */
-      const img = document.createElement('img');
-      img.className = 'preview-img';
-      const reader = new FileReader();
-      reader.onload = (ev) => { img.src = ev.target.result; };
-      reader.readAsDataURL(file);
-      const prev = document.getElementById('photo-preview');
-      prev.innerHTML = '';
-      prev.appendChild(img);
-      document.getElementById('photo-btn-text').textContent = '更换照片 / Change Photo';
-      input.value = ''; // Reset so same file/camera can be selected again
-    } else {
-      const msg = res.error || '未知错误 / Unknown error';
-      alert('上传失败 / Upload failed:\n' + msg);
-      document.getElementById('photo-btn-text').textContent = '选择 / Choose';
-      input.value = '';
-    }
-  } catch(e) {
-    alert('上传失败，请检查网络连接。 / Upload failed, please check your connection.');
-    document.getElementById('photo-btn-text').textContent = '选择 / Choose';
-    input.value = '';
-  }
-}
-
-/* ── Registration submit ── */
-async function submitReg() {
-  const first = document.getElementById('r-first').value.trim();
-  const phone = document.getElementById('r-phone').value.trim();
-  const err   = document.getElementById('reg-err');
-  err.classList.add('hidden');
-
-  if (!first) { showErr(err, '请填写 First Name / First Name is required.'); return; }
-  if (!phone) { showErr(err, '请填写手机号 / Mobile number is required.'); return; }
-
-  const btn = event.currentTarget;
-  btn.textContent = '提交中... / Submitting...';
-  btn.disabled = true;
-
-  try {
-    const body = {
-      firstName:  first,
-      lastName:   document.getElementById('r-last').value.trim(),
-      mobile:     phone,
-      wechat:     document.getElementById('r-wechat').value.trim(),
-      email:      document.getElementById('r-email').value.trim(),
-      photo:      document.getElementById('r-photo').value.trim(),
-      artStyle:   document.getElementById('r-style').value.trim(),
-      favArtist:  document.getElementById('r-artist').value.trim(),
-      experience: document.getElementById('r-exp').value,
-      goals:      document.getElementById('r-goals').value.trim(),
-      birthday:   document.getElementById('r-birthday').value,
-      message:    document.getElementById('r-msg').value.trim(),
-    };
-    const r   = await fetch('/api/register', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
-    const res = await r.json();
-    if (res.success) {
-      document.getElementById('sec-reg').classList.add('hidden');
-      document.getElementById('sec-success').classList.remove('hidden');
-    } else if (res.duplicate === 'pending') {
-      // R2: already in pending queue — show amber warning
-      showErr(err, '⏳ ' + (res.error || '您的申请正在等待审核，请等待老师通知。'));
-    } else if (res.duplicate === 'student') {
-      // R2: already an active student — suggest balance tab
-      showErr(err, '✅ ' + (res.error || '您已是在册学员，请前往"查询余额"页查看课时。'));
-      setTimeout(() => switchTab('bal'), 2500); // auto-switch to balance tab
-    } else {
-      showErr(err, res.error || '提交失败，请重试。');
-    }
-  } catch(e) {
-    showErr(err, '网络错误，请重试。/ Network error, please try again.');
-  } finally {
-    btn.textContent = '提交注册 / Submit Registration';
-    btn.disabled = false;
-  }
-}
